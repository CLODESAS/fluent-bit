#ifndef FLB_INFO_H
#define FLB_INFO_H

/*
 * Pragma fork: __FLB_FILENAME__ se inyecta tambien via -D en CMAKE_C_FLAGS,
 * pero MSBuild puede perderlo en algunos sub-vcxproj (filter_nest, etc.).
 * Garantizar el fallback aqui hace que toda unidad que incluya flb_info.h
 * (todos los plugins lo hacen) compile sin depender de la flag.
 */
#ifndef __FLB_FILENAME__
#define __FLB_FILENAME__ __FILE__
#endif

#define STR_HELPER(s)      #s
#define STR(s)             STR_HELPER(s)

#define FLB_SOURCE_DIR "@CMAKE_SOURCE_DIR@"

/* General flags set by CMakeLists.txt */
@FLB_BUILD_FLAGS@

#define FLB_INFO_FLAGS "@FLB_INFO_FLAGS@"
#endif
